{
  "scenarios": [
    {
      "name": "Immoweb lead is routed to visits as a new lead",
      "type": "inbound_new_lead",
      "email": {
        "from": "info@immoweb.be",
        "subject": "Un visiteur souhaite plus d'informations",
        "body": "Nom : Destrebecq, Frederic\nTelephone : 0470000000\nAdresse mail : frederic@example.com\nDetails de la demande : Je souhaite visiter le bien.\nAdresse : Zeypestraat 44, 1602 Leeuw-Saint-Pierre"
      },
      "expected": {
        "route_to": "visits",
        "message_type": "new_lead"
      }
    },
    {
      "name": "French qualification form submission becomes qualified and hot",
      "type": "form_submission",
      "reply": {
        "purchase_purpose": "Habiter",
        "budget": "300.000 - 400.000 EUR",
        "property_price": "350000",
        "financing_status": "Credit avec accord de principe",
        "project_timing": "1 a 3 mois",
        "interest_reason": "Nous aimons le jardin et la disposition pour notre famille",
        "preferred_days": "Mardi apres-midi, Jeudi matin"
      },
      "expected": {
        "lead_status": "qualified",
        "qualification_rating": "hot",
        "normalized": {
          "purchase_purpose": "live_in",
          "budget": 350000,
          "financing_status": "pre_approved",
          "project_timing": "1_3_months",
          "preferred_days": ["tue_pm", "thu_am"]
        }
      }
    },
    {
      "name": "Dutch qualification form submission with unclear financing stays form_sent",
      "type": "form_submission",
      "reply": {
        "purchase_purpose": "Wonen",
        "budget": "400.000 - 500.000 EUR",
        "property_price": "495000",
        "financing_status": "Nog niet gestart",
        "project_timing": "Geen haast",
        "interest_reason": "Wij vergelijken nog enkele panden maar dit huis past wel bij onze criteria",
        "preferred_days": "Donderdag namiddag"
      },
      "expected": {
        "lead_status": "form_sent",
        "qualification_rating": "weak",
        "normalized": {
          "purchase_purpose": "live_in",
          "budget": 450000,
          "financing_status": "not_started",
          "project_timing": "no_rush",
          "preferred_days": ["thu_pm"]
        }
      }
    },
    {
      "name": "Curious-only qualification form submission is rejected",
      "type": "form_submission",
      "reply": {
        "purchase_purpose": "",
        "budget": "",
        "property_price": "495000",
        "financing_status": "Pas encore demarre",
        "project_timing": "",
        "interest_reason": "Je suis surtout curieux de voir la maison"
      },
      "expected": {
        "lead_status": "closed",
        "qualification_rating": "reject"
      }
    },
    {
      "name": "Form submission can be matched through the internal lead reference",
      "type": "lead_store_ingestion",
      "submission": {
        "lead_ref": "lead_123",
        "email": "frederic@example.com",
        "purchase_purpose": "Habiter",
        "budget": "300.000 - 400.000 EUR",
        "property_price": "350000",
        "financing_status": "Credit avec accord de principe",
        "project_timing": "1 a 3 mois",
        "interest_reason": "Nous aimons le jardin et la disposition pour notre famille",
        "preferred_days": "Mardi apres-midi, Jeudi matin"
      },
      "lead_store": [
        {
          "lead_id": "lead_123",
          "email": "frederic@example.com",
          "status": "form_sent"
        }
      ],
      "expected": {
        "matched_lead_id": "lead_123",
        "processed": true,
        "qualification_rating": "hot"
      }
    },
    {
      "name": "Slot proposal returns at least three realistic openings",
      "type": "slot_proposal",
      "now": "2026-03-11T10:00:00+01:00",
      "working_hours": ["09:00", "18:00"],
      "lead": {
        "commune": "Ixelles"
      },
      "calendar_events": [
        {
          "start": "2026-03-12T09:00:00+01:00",
          "end": "2026-03-12T10:00:00+01:00",
          "commune": "Ixelles"
        },
        {
          "start": "2026-03-12T13:00:00+01:00",
          "end": "2026-03-12T14:00:00+01:00",
          "commune": "Uccle"
        },
        {
          "start": "2026-03-13T11:30:00+01:00",
          "end": "2026-03-13T12:30:00+01:00",
          "commune": "Ixelles"
        }
      ],
      "expected": {
        "minimum_slots": 3
      }
    },
    {
      "name": "Best slot prefers a nearby appointment when available",
      "type": "slot_proposal",
      "now": "2026-03-11T10:00:00+01:00",
      "working_hours": ["09:00", "20:00"],
      "lead": {
        "commune": "Ixelles"
      },
      "calendar_events": [
        {
          "start": "2026-03-12T15:00:00+01:00",
          "end": "2026-03-12T16:00:00+01:00",
          "commune": "Saint-Gilles"
        }
      ],
      "expected": {
        "minimum_slots": 3,
        "first_slot_prefix": "2026-03-12T16:15"
      }
    },
    {
      "name": "Personal events block afternoon visit proposals",
      "type": "slot_proposal",
      "now": "2026-03-11T10:00:00+01:00",
      "working_hours": ["09:00", "20:00"],
      "lead": {
        "commune": "Ixelles"
      },
      "calendar_events": [
        {
          "start": "2026-03-12T13:00:00+01:00",
          "end": "2026-03-12T14:00:00+01:00",
          "commune": "Ixelles",
          "category": "personal"
        }
      ],
      "expected": {
        "minimum_slots": 3,
        "blocked_prefixes": ["2026-03-12T13:00", "2026-03-12T13:15", "2026-03-12T13:30", "2026-03-12T13:45"]
      }
    },
    {
      "name": "Preferred day-parts keep proposals on the requested afternoon",
      "type": "slot_proposal",
      "now": "2026-03-11T10:00:00+01:00",
      "working_hours": ["09:00", "18:00"],
      "lead": {
        "commune": "Ixelles",
        "preferred_days": "Jeudi apres-midi"
      },
      "calendar_events": [],
      "expected": {
        "minimum_slots": 3,
        "first_slot_prefix": "2026-03-12T13:00",
        "only_day_prefix": "2026-03-12"
      }
    },
    {
      "name": "Calendar booking prefers the primary calendar mode",
      "type": "calendar_booking_mode",
      "calendar_connection": {
        "primary_available": true,
        "fallback_available": true
      },
      "expected": {
        "calendar_mode": "primary"
      }
    },
    {
      "name": "Calendar booking falls back to a dedicated calendar when primary is unavailable",
      "type": "calendar_booking_mode",
      "calendar_connection": {
        "primary_available": false,
        "fallback_available": true
      },
      "expected": {
        "calendar_mode": "fallback"
      }
    },
    {
      "name": "Booking conflict triggers a fresh proposal",
      "type": "booking_conflict",
      "now": "2026-03-11T10:00:00+01:00",
      "working_hours": ["09:00", "18:00"],
      "lead": {
        "commune": "Ixelles"
      },
      "requested_slot": {
        "start": "2026-03-12T14:15:00+01:00",
        "end": "2026-03-12T15:00:00+01:00"
      },
      "calendar_events": [
        {
          "start": "2026-03-12T14:00:00+01:00",
          "end": "2026-03-12T15:00:00+01:00",
          "commune": "Ixelles"
        }
      ],
      "expected": {
        "conflict": true,
        "minimum_replacement_slots": 3
      }
    },
    {
      "name": "Pilot onboarding stays client-light without a backoffice",
      "type": "onboarding_surface",
      "setup": {
        "email_channel": "agentmail",
        "calendar_connection": "google_primary",
        "telegram_connected": true,
        "client_backoffice_required": false
      },
      "expected": {
        "smooth_onboarding": true
      }
    },
    {
      "name": "Agent receives a proactive suggestion when no visit is yet planned",
      "type": "agent_suggestion",
      "now": "2026-03-11T10:00:00+01:00",
      "working_hours": ["09:00", "20:00"],
      "lead": {
        "commune": "Ixelles"
      },
      "calendar_events": [],
      "expected": {
        "suggested_day_prefix": "2026-03-12T13:00",
        "reason": "calendar is empty but visit hours allow a proactive proposal"
      }
    },
    {
      "name": "Urgent next-day request with uncertain schedule escalates",
      "type": "urgent_request",
      "now": "2026-03-11T18:00:00+01:00",
      "requested_slot": {
        "start": "2026-03-12T10:00:00+01:00",
        "end": "2026-03-12T10:45:00+01:00"
      },
      "calendar_visibility": "incomplete",
      "expected": {
        "escalate": true
      }
    },
    {
      "name": "Unknown capacity triggers an agent question instead of grouped assumption",
      "type": "capacity_guardrail",
      "property": {
        "capacity_known": false,
        "grouped_visit_requested": true
      },
      "expected": {
        "ask_agent": true
      }
    },
    {
      "name": "Weekly planning groups qualified leads into clusters",
      "type": "weekly_planning",
      "now": "2026-03-13T17:00:00+01:00",
      "working_hours": ["09:00", "18:00"],
      "leads": [
        {
          "status": "qualified",
