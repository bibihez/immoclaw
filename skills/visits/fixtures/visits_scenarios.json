    },
    {
      "name": "Agent receives a proactive suggestion when no visit is yet planned",
      "type": "agent_suggestion",
      "now": "2026-03-11T10:00:00+01:00",
      "working_hours": ["09:00", "20:00"],
      "lead": {
        "commune": "Ixelles"
      },
      "calendar_events": [],
      "expected": {
        "suggested_day_prefix": "2026-03-12T13:00",
        "reason": "calendar is empty but visit hours allow a proactive proposal"
      }
    },
    {
      "name": "Urgent next-day request with uncertain schedule escalates",
      "type": "urgent_request",
      "now": "2026-03-11T18:00:00+01:00",
      "requested_slot": {
        "start": "2026-03-12T10:00:00+01:00",
        "end": "2026-03-12T10:45:00+01:00"
      },
      "calendar_visibility": "incomplete",
      "expected": {
        "escalate": true
      }
    },
    {
      "name": "Unknown capacity triggers an agent question instead of grouped assumption",
      "type": "capacity_guardrail",
      "property": {
        "capacity_known": false,
        "grouped_visit_requested": true
      },
      "expected": {
        "ask_agent": true
      }
    },
